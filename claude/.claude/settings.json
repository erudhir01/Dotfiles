{
  "theme": "dark",
  "statusLine": {
    "type": "command",
    "command": "bash /home/erudhir/dotfiles/claude/.claude/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset --hard*)"
    ]
  }
}
